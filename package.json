{
  "name": "jiu-tracker-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Jiu Tracker monorepo - Backend API and Mobile App",
  "workspaces": [
    "jiu-tracker-mobile",
    "jiu-tracker-nest",
    "jiu-tracker-landing",
    "packages/*"
  ],
  "scripts": {
    "shared:build": "npm run build -w @jiu-tracker/shared",
    "shared:watch": "npm run watch -w @jiu-tracker/shared",
    "backend:install": "cd jiu-tracker-nest && npm install",
    "backend:dev": "cd jiu-tracker-nest && npm run start:dev",
    "backend:build": "npm run build -w jiu-tracker-nest",
    "backend:test": "cd jiu-tracker-nest && npm test",
    "backend:lint": "cd jiu-tracker-nest && npm run lint",
    "mobile:install": "cd jiu-tracker-mobile && npm install",
    "mobile:start": "cd jiu-tracker-mobile && npm start",
    "mobile:android": "cd jiu-tracker-mobile && npm run android",
    "mobile:ios": "cd jiu-tracker-mobile && npm run ios",
    "mobile:web": "cd jiu-tracker-mobile && npm run web",
    "mobile:test": "cd jiu-tracker-mobile && npm test",
    "mobile:lint": "cd jiu-tracker-mobile && npm run lint",
    "landing:dev": "cd jiu-tracker-landing && npm run dev",
    "landing:build": "cd jiu-tracker-landing && npm run build",
    "landing:start": "cd jiu-tracker-landing && npm run start",
    "landing:lint": "cd jiu-tracker-landing && npm run lint",
    "install:all": "npm install",
    "build:all": "npm run shared:build && npm run backend:build",
    "dev": "npm-run-all --parallel backend:dev mobile:web",
    "dev:backend": "npm run backend:dev",
    "dev:mobile": "npm run mobile:start",
    "dev:landing": "npm run landing:dev"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}

