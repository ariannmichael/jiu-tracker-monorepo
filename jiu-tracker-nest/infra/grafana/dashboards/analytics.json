{
  "title": "Analytics Pipeline",
  "panels": [
    {
      "id": 1,
      "title": "Recomputations total",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(analytics_recomputation_total)",
          "legendFormat": "Total"
        }
      ],
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Recomputation duration (p95)",
      "type": "graph",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(analytics_recomputation_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 }
    }
  ],
  "schemaVersion": 38,
  "version": 1
}
