EXPO_PUBLIC_API_URL=https://your-api.example.com/api
# Must match the subscription Product ID in App Store Connect & Google Play (same string on both stores).
EXPO_PUBLIC_PREMIUM_PRODUCT_ID=JiuTrackerPremium

# EAS Build (cloud) does not read your laptop .env unless it is committed. eas.json sets
# EXPO_PUBLIC_PREMIUM_PRODUCT_ID for iOS/Android builds; add EXPO_PUBLIC_API_URL in EAS
# (Project → Environment variables) or in eas.json "env" if needed.
