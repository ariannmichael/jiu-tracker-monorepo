+package expo.modules.inapppurchases
+
+import android.os.Bundle
+import expo.modules.kotlin.modules.Module
+import expo.modules.kotlin.modules.ModuleDefinition
+import expo.modules.kotlin.Promise
+
+class InAppPurchasesModule : Module() {
+  private var mBillingManager: BillingManager? = null
+
+  override fun definition() = ModuleDefinition {
+    Name("ExpoInAppPurchases")
+
+    Events(BillingManager.PURCHASES_UPDATED_EVENT)
+
+    AsyncFunction("connectAsync") { promise: Promise ->
+      val activity = appContext.currentActivity
+      if (activity == null) {
+        promise.reject("E_ACTIVITY_UNAVAILABLE", "Activity is not available", null)
+        return@AsyncFunction
+      }
+      mBillingManager = BillingManager(activity) { eventName, bundle ->
+        this@InAppPurchasesModule.sendEvent(eventName, bundleToMap(bundle))
+      }
+      mBillingManager!!.startConnection(promise)
+    }
+
+    AsyncFunction("getProductsAsync") { itemList: List<String>, promise: Promise ->
+      mBillingManager?.queryPurchasableItems(itemList, promise)
+        ?: promise.reject("E_NOT_CONNECTED", "Not connected to billing service", null)
+    }
+
+    AsyncFunction("getPurchaseHistoryAsync") { options: Map<String, Any?>?, promise: Promise ->
+      val useCache = (options?.get("useGooglePlayCache") as? Boolean) ?: true
+      if (useCache) {
+        mBillingManager?.queryPurchases(promise)
+          ?: promise.reject("E_NOT_CONNECTED", "Not connected to billing service", null)
+      } else {
+        mBillingManager?.queryPurchaseHistoryAsync(promise)
+          ?: promise.reject("E_NOT_CONNECTED", "Not connected to billing service", null)
+      }
+    }
+
+    AsyncFunction("purchaseItemAsync") { skuId: String, details: Map<String, Any?>?, promise: Promise ->
+      mBillingManager?.purchaseItemAsync(skuId, promise)
+        ?: promise.reject("E_NOT_CONNECTED", "Not connected to billing service", null)
+    }
+
+    AsyncFunction("getBillingResponseCodeAsync") { promise: Promise ->
+      promise.resolve(mBillingManager?.billingClientResponseCode ?: BillingManager.BILLING_MANAGER_NOT_INITIALIZED)
+    }
+
+    AsyncFunction("finishTransactionAsync") { purchaseToken: String, consume: Boolean, promise: Promise ->
+      if (consume) {
+        mBillingManager?.consumeAsync(purchaseToken, promise)
+          ?: promise.reject("E_NOT_CONNECTED", "Not connected to billing service", null)
+      } else {
+        mBillingManager?.acknowledgePurchaseAsync(purchaseToken, promise)
+          ?: promise.reject("E_NOT_CONNECTED", "Not connected to billing service", null)
+      }
+    }
+
+    AsyncFunction("disconnectAsync") { promise: Promise ->
+      mBillingManager?.destroy()
+      mBillingManager = null
+      promise.resolve(null)
+    }
+  }
+
+  private fun bundleToMap(bundle: Bundle): Map<String, Any?> {
+    val map = mutableMapOf<String, Any?>()
+    for (key in bundle.keySet()) {
+      @Suppress("DEPRECATION")
+      val value = bundle.get(key)
+      map[key] = if (value is ArrayList<*>) {
+        value.filterIsInstance<Bundle>().map { bundleToMap(it) }
+      } else {
+        value
+      }
+    }
+    return map
+  }
+}
